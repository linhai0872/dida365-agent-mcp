# Region: "china" (dida365.com) or "international" (ticktick.com)
DIDA365_REGION=china

# OAuth2 credentials
# China: https://developer.dida365.com/manage
# International: https://developer.ticktick.com/manage
DIDA365_CLIENT_ID=your_client_id
DIDA365_CLIENT_SECRET=your_client_secret

# Access token (skip OAuth flow if provided directly)
DIDA365_ACCESS_TOKEN=

# OAuth redirect URI
DIDA365_REDIRECT_URI=http://localhost:8000/oauth/callback

# V2 Private API session token (optional)
# Copy from browser DevTools: Application > Cookies > t
# Enables: tags, habits, folders, parent tasks
DIDA365_V2_SESSION_TOKEN=

# Transport: "stdio", "streamable-http", or "sse" (legacy, for older clients)
TRANSPORT=stdio

# Host/port settings (only used when TRANSPORT=http or sse)
HOST=0.0.0.0
PORT=8000
